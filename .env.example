# Server Configuration
PORT=9090
HOST=0.0.0.0
NODE_ENV=production

# CORS Configuration
# Set to a specific origin in production (e.g., https://carbide.network)
# or leave empty to use the default based on NODE_ENV
CORS_ORIGIN=

# Discovery Service Configuration
HEALTH_CHECK_INTERVAL=30000
PROVIDER_TIMEOUT=300000
MAX_SEARCH_RESULTS=100

# Logging
LOG_LEVEL=info

# Authentication
AUTH_SECRET=
JWT_SECRET=
JWT_EXPIRES_IN=24h

# Blockchain / Payment Verification
VERIFIER_PRIVATE_KEY=
ESCROW_CONTRACT=
USDC_ADDRESS=
CHAIN_ID=421614
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
