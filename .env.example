# Server
PORT=9090
HOST=0.0.0.0
NODE_ENV=production

# CORS — leave empty to default to https://carbide.network in production
CORS_ORIGIN=

# Discovery loop
HEALTH_CHECK_INTERVAL=30000
PROVIDER_TIMEOUT=300000
MAX_SEARCH_RESULTS=100

# Logging
LOG_LEVEL=info

# Persistence
DATABASE_PATH=./data/carbide-discovery.db

# Authentication (set AUTH_ENABLED=false to skip in development)
AUTH_ENABLED=true
AUTH_SECRET=
JWT_SECRET=
JWT_EXPIRES_IN=1h

# Solana / on-chain integration
# Cluster label is informational; the indexer connects to CARBIDE_SOLANA_RPC_URL.
CARBIDE_SOLANA_CLUSTER=devnet
CARBIDE_SOLANA_RPC_URL=https://api.devnet.solana.com
# Optional explicit websocket; leave empty to derive from the RPC URL.
CARBIDE_SOLANA_WS_URL=

# Deployed program IDs. Leaving CARBIDE_REGISTRY_PROGRAM_ID empty disables the indexer.
CARBIDE_REGISTRY_PROGRAM_ID=
CARBIDE_ESCROW_PROGRAM_ID=

# SPL token mint used for payments (devnet USDC shown).
CARBIDE_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Path to a solana-keygen JSON keypair for the verifier signer.
# Generate with: solana-keygen new -o /path/to/verifier.json
# The pubkey must be whitelisted via carbide_escrow.add_verifier before use.
CARBIDE_VERIFIER_KEYPAIR_PATH=
