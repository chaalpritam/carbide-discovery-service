{
  "name": "carbide-discovery-service",
  "version": "1.0.0",
  "description": "Carbide Network Discovery Service - Marketplace for decentralized storage providers",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc && cp -r src/database/migrations dist/database/",
    "serve": "npm run build && npm start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "carbide",
    "discovery",
    "storage",
    "marketplace",
    "p2p"
  ],
  "author": "Chaal Pritam",
  "license": "MIT",
  "dependencies": {
    "fastify": "^4.25.2",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "better-sqlite3": "^11.7.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@vitest/coverage-v8": "^4.0.18",
    "pino-pretty": "^10.3.1",
    "tsx": "^4.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
